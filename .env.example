# FitAI 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# ==================== 文本生成配置 ====================

# AI API 地址 (OpenAI 兼容格式)
VITE_AI_BASE_URL=https://api.openai.com/v1

# API 密钥 (从 OpenAI/DashScope/其他 AI 服务商获取)
VITE_AI_API_KEY=your-api-key-here

# 模型名称
VITE_AI_MODEL=gpt-4

# ==================== 可选配置 ====================

# 创造性参数 (0-1, 越高质量越好但越慢)
# VITE_AI_TEMPERATURE=0.7

# 超时时间 (毫秒)
# VITE_AI_TIMEOUT=300000
